# Copy to .env and edit as needed

# Data source:
#   "json_cache" (default, no network; reads .json/.ndjson/.csv from DATA_DIR)
#   "playwright" (live scrape via headless Chromium — Cloudflare-safe)
#   "otodom"     (legacy httpx+BeautifulSoup scraper; usually Cloudflare-blocked)
# NOTE: scraping is the operator's responsibility under otodom.pl ToS.
DATA_SOURCE=json_cache

# Directory for JSON/CSV cache files and SQLite DB
DATA_DIR=./data

# SQLite database path
DATABASE_URL=sqlite:///./data/rzeszow.db

# --- Otodom scraper settings (used when DATA_SOURCE=playwright or otodom) ---
OTODOM_BASE_URL=https://www.otodom.pl
# Throttle: seconds between requests (minimum 2 to be polite)
REQUEST_DELAY_S=2.0
# Max search-result pages to fetch per transaction type (sale/rent)
OTODOM_MAX_PAGES=5

# --- Renovation cost model (PLN per m²) ---
RENO_COST_READY=0
RENO_COST_FINISHING=1800
RENO_COST_RENOVATION=2800

# --- ROI assumptions ---
VACANCY_RATE=0.08
ANNUAL_COSTS_RATE=0.20

# --- Deal score weights (must sum to 1.0) ---
SCORE_WEIGHT_DISCOUNT=0.5
SCORE_WEIGHT_YIELD=0.4
SCORE_WEIGHT_PRICE=0.1

# --- Scheduler ---
SCHEDULE_INTERVAL_HOURS=24

# --- Finishing conditions to include (comma-separated) ---
INCLUDED_CONDITIONS=ready,finishing,renovation

# --- CORS (backend) ---
# Comma-separated origins allowed to call the API.
# Use * to allow all origins (no cookies/credentials sent — fine for this app).
# On Railway set this to your frontend service URL, e.g.:
#   CORS_ORIGINS=https://your-frontend.up.railway.app
CORS_ORIGINS=*
